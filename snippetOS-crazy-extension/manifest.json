{
  "manifest_version": 3,
  "name": "SnippetOS",
  "version": "4.0",
  "description": "Raycast-style snippet manager with command palette and instant paste",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "commands": {
    "open_palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space"
      },
      "description": "Open SnippetOS Command Palette"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"]
    }
  ]
}
